' MAINCP2.FRM
Option Explicit
Declare Sub extsub0366 Lib "chrnob.dll" Alias "GETVLV" (p1!)
Declare Sub extsub1437 Lib "chrnob.dll" Alias "SETDIS" (p1%, p2%)
Declare Sub extsub142D Lib "chrnob.dll" Alias "SETINL" (p1%, p2%)
Declare Sub extsub0348 Lib "chrnob.dll" Alias "SETPMP" (p1%, p2%)
Declare Sub extsub1423 Lib "chrnob.dll" Alias "SETTRM" (p1!, p2%)

Sub Command1_Click (Index%)
Static m001C(12) As Single
Dim l0032 As Integer
Dim l0034 As Integer
Dim l0038 As Integer
Dim l003C As Integer
  Call extsub0366(m001C(0))
  l0032% = 1 - Index Mod 2
  If Index < 6 Then
   l0034% = Int(Index / 2) + 3
   If l0032% = 1 Then
    If (m001C(l0034%) > .99 And m001C(l0034% + 6) < .01) Then
      gv008C = 0
      l0038% = l0034% + 7
      l003C% = fn0528(l0038%, Me)
      If gv01CE(l0034%) <> 1 And l003C% = 0 Then
       Call sub09C9(1, model_timer)
      End If
     Call extsub0348(l0034%, 1)
    End If
   Else
    Call extsub0348(l0034%, 0)
   End If
  ElseIf Index < 12 Then
    l0034% = Int((Index - 6) / 2) + 3
    Call extsub142D(l0032%, l0034%)
  ElseIf Index < 18 Then
     l0034% = Int((Index - 12) / 2) + 3
     Call extsub1437(l0032%, l0034%)
  End If
End Sub

Sub Form_Load ()
 gv00D8 = True
End Sub

Sub Form_Unload (Cancel As Integer)
 gv00D8 = False
End Sub

Sub Spin1_SpinDown ()
 DoEvents
 Call extsub1423(-.02, 1)
End Sub

Sub Spin1_SpinUp ()
 DoEvents
 Call extsub1423(.02, 1)
End Sub

